[Unit]
Description=Taiko Rating Pro API (Gunicorn)
After=network.target

[Service]
Type=simple
User=__APP_USER__
Group=__APP_USER__
WorkingDirectory=__APP_DIR__
Environment=PYTHONPATH=__APP_DIR__/src
ExecStart=__APP_DIR__/.venv/bin/gunicorn -c __APP_DIR__/deploy/ubuntu/gunicorn.conf.py taiko_rating.api:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
